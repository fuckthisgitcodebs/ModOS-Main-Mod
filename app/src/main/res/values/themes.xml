<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ModOS" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/cyan_primary</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.Recents.AmoledTranslucent" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <!-- FIX: Removed android:windowFullscreen=true — was fighting enableEdgeToEdge()
             causing status bar to flash in on enter animation then get hidden by theme -->
        <item name="android:windowContentOverlay">@null</item>
        <item name="colorPrimary">@color/cyan_primary</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
